{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",  
  "InboxProcessing": {
    "PartitionCount": 2,
    "LockExpirySeconds": 30,
    "LockRenewIntervalSeconds": 20,
    "PollingIntervalMs": 200
  },
  "MessagingOutboxProcessing": {
    "PartitionCount": 2,
    "LockExpirySeconds": 30,
    "LockRenewIntervalSeconds": 20,
    "PollingIntervalMs": 5000,
    "PubSubName": "pubsub",
    "TopicName": "transaction-events"
  }
}
