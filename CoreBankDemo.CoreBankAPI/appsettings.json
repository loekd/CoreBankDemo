{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Features": {
    "UseInbox": false
  },
  "InboxProcessing": {
    "PartitionCount": 2,
    "LockExpirySeconds": 30,
    "LockRenewIntervalSeconds": 20
  }
}
